{
  "name": "valid",
  "version": "0.1.0",
  "description": "MCP server that composites screenshots and text into rendered PNG validation images",
  "type": "module",
  "bin": {
    "valid": "dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --external:sharp --external:playwright-core --outfile=dist/index.js --banner:js='#!/usr/bin/env node'",
    "postinstall": "playwright-core install chromium",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "playwright-core": "^1.52.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "esbuild": "^0.25.2",
    "typescript": "^5.8.3",
    "@types/node": "^22.15.2",
    "tsx": "^4.19.4"
  }
}
