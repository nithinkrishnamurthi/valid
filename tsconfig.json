{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "valid-mcp/dist",
    "rootDir": "valid-mcp/src",
    "declaration": true,
    "skipLibCheck": true,
